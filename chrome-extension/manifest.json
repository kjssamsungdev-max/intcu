{
  "manifest_version": 3,
  "name": "Intcu — The Intelligent Cue",
  "short_name": "Intcu",
  "version": "1.0.0",
  "description": "AI teleprompter overlay with live conversation copilot. Works on Zoom, Meet, Teams, and any webpage.",
  "permissions": ["activeTab", "storage", "contextMenus", "sidePanel"],
  "host_permissions": ["https://intcu.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
